<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="12dp" android:hint="Contraseña actual"
        app:passwordToggleEnabled="true"
        app:boxStrokeColor="#2E7D32" app:hintTextColor="#2E7D32">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edt_password_actual"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="textPassword" android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="12dp" android:hint="Nueva contraseña"
        app:passwordToggleEnabled="true"
        app:boxStrokeColor="#2E7D32" app:hintTextColor="#2E7D32"
        app:helperText="Mínimo 6 caracteres">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edt_password_nueva"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="textPassword" android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Confirmar nueva contraseña"
        app:passwordToggleEnabled="true"
        app:boxStrokeColor="#2E7D32" app:hintTextColor="#2E7D32">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edt_password_confirmar"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:inputType="textPassword" android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>