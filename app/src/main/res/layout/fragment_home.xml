<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══ CABECERA ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1B5E20"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="40dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txt_saludo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Buenos días 👋"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:id="@+id/txt_fecha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="#A5D6A7"
                        android:layout_marginTop="3dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/txt_nombre_usuario"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#C8E6C9" />

                    <TextView
                        android:id="@+id/txt_cargo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="#81C784" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ══ KPIs flotantes ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:layout_marginTop="-28dp">

            <!-- Registros hoy -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp">
                    <TextView
                        android:id="@+id/txt_total_registros"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="#2E7D32" />
                    <View
                        android:layout_width="30dp"
                        android:layout_height="2dp"
                        android:background="#4CAF50"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Registros hoy"
                        android:textSize="10sp"
                        android:textColor="#757575"
                        android:gravity="center" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Total kg -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp">
                    <TextView
                        android:id="@+id/txt_total_kg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#1565C0" />
                    <View
                        android:layout_width="30dp"
                        android:layout_height="2dp"
                        android:background="#42A5F5"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total kg hoy"
                        android:textSize="10sp"
                        android:textColor="#757575"
                        android:gravity="center" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Pendientes -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp">
                    <TextView
                        android:id="@+id/txt_pendientes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="#E65100" />
                    <View
                        android:layout_width="30dp"
                        android:layout_height="2dp"
                        android:background="#FF7043"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sin sincronizar"
                        android:textSize="10sp"
                        android:textColor="#757575"
                        android:gravity="center" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>


        </LinearLayout>

        <!-- ══ ACCIONES RÁPIDAS ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_nuevo_registro"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="+ Nuevo Registro"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="#2E7D32"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_add"
                app:iconTint="#FFFFFF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ver_historial"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Historial"
                android:textSize="13sp"
                android:textStyle="bold"
                app:backgroundTint="#1565C0"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_historial"
                app:iconTint="#FFFFFF" />

        </LinearLayout>

        <!-- ══ GRÁFICO PIE — Distribución por categoría ══ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Título -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="18dp"
                        android:background="#2E7D32"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DISTRIBUCIÓN POR CATEGORÍA"
                        android:textSize="11sp"
                        android:textColor="#2E7D32"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Este mes"
                        android:textSize="10sp"
                        android:textColor="#9E9E9E"
                        android:gravity="end" />

                </LinearLayout>

                <!-- Gráfico Pie -->
                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pie_chart"
                    android:layout_width="match_parent"
                    android:layout_height="220dp" />

                <!-- Barras de porcentaje manual -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp">

                    <!-- Peligroso -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="#F44336"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Peligroso"
                            android:textSize="12sp"
                            android:textColor="#333333" />

                        <LinearLayout
                            android:layout_width="120dp"
                            android:layout_height="8dp"
                            android:background="#FFEBEE"
                            android:layout_marginEnd="8dp">
                            <View
                                android:id="@+id/bar_pct_peligroso"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:background="#F44336" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/txt_pct_peligroso"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#F44336"
                            android:gravity="end" />

                    </LinearLayout>

                    <!-- No Peligroso -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="#4CAF50"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="No Peligroso"
                            android:textSize="12sp"
                            android:textColor="#333333" />

                        <LinearLayout
                            android:layout_width="120dp"
                            android:layout_height="8dp"
                            android:background="#E8F5E9"
                            android:layout_marginEnd="8dp">
                            <View
                                android:id="@+id/bar_pct_no_peligroso"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:background="#4CAF50" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/txt_pct_no_peligroso"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#2E7D32"
                            android:gravity="end" />

                    </LinearLayout>

                    <!-- Especial -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="#9C27B0"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Especial"
                            android:textSize="12sp"
                            android:textColor="#333333" />

                        <LinearLayout
                            android:layout_width="120dp"
                            android:layout_height="8dp"
                            android:background="#F3E5F5"
                            android:layout_marginEnd="8dp">
                            <View
                                android:id="@+id/bar_pct_especial"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:background="#9C27B0" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/txt_pct_especial"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#6A1B9A"
                            android:gravity="end" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ GRÁFICO BARRAS — Top 5 tipos ══ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="18dp"
                        android:background="#1565C0"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOP 5 RESIDUOS — KG RECOLECTADOS"
                        android:textSize="11sp"
                        android:textColor="#1565C0"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Este mes"
                        android:textSize="10sp"
                        android:textColor="#9E9E9E"
                        android:gravity="end" />

                </LinearLayout>

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/bar_chart"
                    android:layout_width="match_parent"
                    android:layout_height="220dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>



        <!-- ══ ÚLTIMOS REGISTROS DEL DÍA ══ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="18dp"
                        android:background="#E65100"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ÚLTIMOS REGISTROS DEL DÍA"
                        android:textSize="11sp"
                        android:textColor="#E65100"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_ultimos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>