<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottomsheet">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginTop="12dp"
        android:background="#BDBDBD" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_info_details"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Términos de Uso"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ECOLIM S.A.C. — Versión 1.0"
                android:textSize="12sp"
                android:textColor="#9E9E9E" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE" />

    <!-- Contenido con scroll -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="400dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. ACEPTACIÓN DE LOS TÉRMINOS"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:layout_marginBottom="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Al utilizar la aplicación ECOLIM, usted acepta cumplir con los presentes Términos de Uso. Si no está de acuerdo con alguno de estos términos, le solicitamos que no utilice la aplicación."
                android:textSize="13sp"
                android:textColor="#444444"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2. USO DE LA APLICACIÓN"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:layout_marginBottom="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ECOLIM es una herramienta diseñada exclusivamente para el registro y gestión de residuos sólidos dentro de las instalaciones de ECOLIM S.A.C. Su uso está restringido al personal autorizado de la empresa. Queda prohibido su uso para fines distintos a los establecidos."
                android:textSize="13sp"
                android:textColor="#444444"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3. RESPONSABILIDADES DEL USUARIO"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:layout_marginBottom="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="El usuario es responsable de:\n\n• Mantener la confidencialidad de sus credenciales de acceso.\n• Registrar información veraz y precisa sobre los residuos recolectados.\n• No compartir su cuenta con terceros.\n• Reportar cualquier uso no autorizado a su supervisor inmediato."
                android:textSize="13sp"
                android:textColor="#444444"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4. PROPIEDAD INTELECTUAL"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:layout_marginBottom="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Todos los derechos de la aplicación, incluyendo su diseño, código fuente, logotipos y contenido, son propiedad exclusiva de ECOLIM S.A.C. Queda prohibida su reproducción, distribución o modificación sin autorización escrita."
                android:textSize="13sp"
                android:textColor="#444444"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5. LIMITACIÓN DE RESPONSABILIDAD"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:layout_marginBottom="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ECOLIM S.A.C. no será responsable por daños derivados del mal uso de la aplicación, pérdida de datos por causas ajenas a la empresa, o interrupciones en el servicio por mantenimiento o fuerza mayor."
                android:textSize="13sp"
                android:textColor="#444444"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="6. MODIFICACIONES"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:layout_marginBottom="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ECOLIM S.A.C. se reserva el derecho de modificar estos términos en cualquier momento. Los cambios serán notificados a través de la aplicación y entrarán en vigor inmediatamente después de su publicación."
                android:textSize="13sp"
                android:textColor="#444444"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7. CONTACTO"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:layout_marginBottom="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Para consultas relacionadas con estos términos, puede contactarnos en:\n\n📧 sirsmith.limas@gmail.com\n📞 +51 900018973\n📍 Huánuco, Perú"
                android:textSize="13sp"
                android:textColor="#444444"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="8dp" />

        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE" />

    <!-- Botón aceptar -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_aceptar_terminos"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="20dp"
        android:text="Entendido"
        android:textStyle="bold"
        app:backgroundTint="#2E7D32"
        app:cornerRadius="12dp"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

</LinearLayout>