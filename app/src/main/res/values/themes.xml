    </style>

    <!-- ══════════════════════════════════════════════════════════════════
         SPLASH — sin action bar
    ═══════════════════════════════════════════════════════════════════ -->
    <style name="Theme.Ecolim.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/verde_primary</item>
