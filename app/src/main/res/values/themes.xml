<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ══════════════════════════════════════════════════════════════════
         TEMA BASE — Verde ECOLIM (predeterminado)
         Parent: Theme.MaterialComponents.DayNight.NoActionBar
         Esto garantiza que colorBackground, colorSurface, colorOnSurface
         y todos los attrs de Material estén disponibles sin errores.
    ═══════════════════════════════════════════════════════════════════ -->
    <style name="Theme.Ecolim" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Colores primarios -->
        <item name="colorPrimary">@color/verde_primary</item>
        <item name="colorPrimaryVariant">@color/verde_dark</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Colores secundarios -->
        <item name="colorSecondary">@color/verde_secondary</item>
        <item name="colorSecondaryVariant">@color/verde_dark</item>
        <item name="colorOnSecondary">#FFFFFF</item>

        <!-- Superficie y fondo — Material Components los provee automáticamente -->
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#1A1A1A</item>
        <item name="android:colorBackground">#F2F2F7</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/verde_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- SwitchMaterial -->
        <item name="colorControlActivated">@color/verde_primary</item>
        <item name="colorSwitchThumbNormal">#FFFFFF</item>

        <!-- Sin fuente personalizada — usa la del sistema -->
    </style>

    <!-- ══════════════════════════════════════════════════════════════════
         TEMA OSCURO — se activa con AppCompatDelegate.MODE_NIGHT_YES
         DayNight lo maneja automáticamente con los valores en values-night
    ═══════════════════════════════════════════════════════════════════ -->
    <style name="Theme.Ecolim.Dark" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/verde_primary</item>
        <item name="colorPrimaryVariant">@color/verde_dark</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">@color/verde_secondary</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">#F0F0F0</item>
        <item name="android:colorBackground">#121212</item>
        <item name="android:statusBarColor">#1B5E20</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorControlActivated">@color/verde_primary</item>
    </style>

    <!-- ══════════════════════════════════════════════════════════════════
         TEMA AZUL CORPORATIVO
    ═══════════════════════════════════════════════════════════════════ -->
    <style name="Theme.Ecolim.Azul" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#1565C0</item>
        <item name="colorPrimaryVariant">#0D47A1</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#42A5F5</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#1A1A1A</item>
        <item name="android:colorBackground">#F0F4FF</item>
        <item name="android:statusBarColor">#0D47A1</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorControlActivated">#1565C0</item>
    </style>

    <!-- ══════════════════════════════════════════════════════════════════
         TEMA NARANJA ENERGÉTICO
    ═══════════════════════════════════════════════════════════════════ -->
