        <item name="android:statusBarColor">#BF360C</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorControlActivated">#E65100</item>
    </style>

    <!-- ══════════════════════════════════════════════════════════════════
         TEMA GRIS PROFESIONAL
    ═══════════════════════════════════════════════════════════════════ -->
